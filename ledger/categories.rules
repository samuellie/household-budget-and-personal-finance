{
  "_comment": "Category rules for auto-classifying bank transactions. Matched case-insensitively in priority order (highest first). First match wins.",
  "rules": [
    {
      "pattern": "TINKERVE TECHNOLOGY|SVG GIRO CR.*TINKERVE|GIRO.*PAYOUT.*TINKERVE",
      "account": "Income:Salary",
      "priority": 10,
      "note": "Samuel's employer"
    },
    {
      "pattern": "INTERBANK GIRO.*SALARY|SALARY.*GIRO|GAJI",
      "account": "Income:Salary",
      "priority": 8
    },
    {
      "pattern": "INT/HB/PFT|INTEREST EARNED|FAEDAH KREDIT|PROFIT.*CREDIT",
      "account": "Income:Interest",
      "priority": 9
    },
    {
      "pattern": "REFUND|REVERSAL|REBAT|PRE-AUTH REFUND",
      "account": "Income:Refund",
      "priority": 8
    },
    {
      "pattern": "WONG FUI YEE.*(HOUSE|LOAN|MORTGAGE)|(HOUSE LOAN|MORTGAGE).*WONG FUI YEE|WONG FUI YEE.*LOAN AND",
      "account": "Expenses:Housing:Mortgage",
      "priority": 10,
      "note": "Monthly mortgage to Fui Yee CIMB account (RM3,551/mth, started Jul 2025)"
    },
    {
      "pattern": "DAVID LIAN YOON WAI.*Rental|IBK.*DAVID LIAN.*RENTAL",
      "account": "Expenses:Housing:Rent",
      "priority": 10,
      "note": "Rental payment to landlord"
    },
    {
      "pattern": "MAINTENANCE FEE|SERVICE CHARGE|CONDO|JOINT MANAGEMENT",
      "account": "Expenses:Housing:Maintenance",
      "priority": 7
    },
    {
      "pattern": "GRABFOOD|GRAB FOOD|FOODPANDA|SHOPEEFOOD|SHOPEE FOOD|DAHMAKAN|BEEPIT",
      "account": "Expenses:Dining",
      "priority": 10
    },
    {
      "pattern": "JAYA GROCER|VILLAGE GROCER|AEON.*SUPERMARKET|TESCO|LOTUS|MYDIN|99 SPEED|COLD STORAGE|JASONS|BENS INDEPENDENT",
      "account": "Expenses:Groceries",
      "priority": 9
    },
    {
      "pattern": "RESTAURANT|RESTORAN|MAMAK|KOPITIAM|BISTRO|MCDONALD|KFC|PIZZA|DOMINO|BURGER KING|A&W|SUBWAY|STARBUCKS|ZUS COFFEE|OLD TOWN|SECRET RECIPE|SUSHI|MARRYBROWN",
      "account": "Expenses:Dining",
      "priority": 6
    },
    {
      "pattern": "PETRONAS|SHELL.*STATION|PETRON|CALTEX|BHP.*FUEL",
      "account": "Expenses:Transport:Fuel",
      "priority": 10
    },
    {
      "pattern": "PARKING|PARK.*METER|DBKL PARKING|APCOA|CAR PARK",
      "account": "Expenses:Transport:Parking",
      "priority": 9
    },
    {
      "pattern": "GRAB.*CAR|GRABCAR|GRAB.*RIDE|GOJEK",
      "account": "Expenses:Transport:Grab",
      "priority": 9
    },
    {
      "pattern": "RAPIDKL|PRASARANA|KTM |LRT |MRT |MONORAIL|KLIAEKSPRES|KLIA EKSPRES",
