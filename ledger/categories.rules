    },
    {
      "pattern": "STRICTLY GOURMET|DE MARKET|PAPASAN|ROAST MEAT|TK BAKERY|OFFFFIVE COFFEE|CROISSSE|JONETZ|AYAM PENYET|GT-KL GATEWAY|SB093|NLBH BANGSAR|MALA PARADISE|HONG FU|BIG BABA|TSUYOI|APSB_S.PK",
      "account": "Expenses:Dining",
