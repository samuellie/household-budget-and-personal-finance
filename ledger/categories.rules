    {
      "pattern": "GP STRICTLY GOURMET|GP.*RESTAURANT|GP.*CAFE|GP.*BAKERY|GP.*DIM SUM|GP.*ROAST MEAT|GP.*NOODLE|GP.*MALA|GP.*PAPASAN|GP HONG FU|GP BIG BABA|GP.*AYAM|GP NLBH|GP.*DE MARKET|GP GT-KL|GP.*EATERY|GP.*KITCHEN|GP.*FOOD|GP.*BISTRO",
